# FlowGO Environment Variables Template
# Copy this file to .env.local and fill in your API keys
# 
# IMPORTANT: .env.local is gitignored and will NOT be committed to the repository

# TomTom Maps API Key
# Get your free API key at: https://developer.tomtom.com
# 1. Sign up for a free account
# 2. Create a new application
# 3. Copy your API key and paste it below
VITE_TOMTOM_API_KEY=your_tomtom_api_key_here

# Alternative variable name (you can use either):
# VITE_TOMTOM_KEY=your_tomtom_api_key_here

# Backend API URL (optional - defaults to http://localhost:8000)
# VITE_API_URL=http://localhost:8000
# VITE_MONITORING_API=http://localhost:8000
